# Neon Postgres connection string
# หาได้จาก Neon Dashboard > Connection Details (เลือกแบบ Pooled connection)
# ต้องมี ?sslmode=require ต่อท้าย
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# URL จริงของเว็บเมื่อ deploy แล้ว (ใช้สร้าง absolute URL ให้ Open Graph / Facebook preview)
# เช่น https://forexthailand.com — ตอน dev ปล่อยว่างได้ จะใช้ http://localhost:3000
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# n8n webhook สำหรับสั่งโพส Facebook หลังกดอนุมัติใน /admin
# เว็บจะ POST { id } ไปที่ URL นี้ — ถ้าปล่อยว่าง ระบบจะข้ามขั้นยิง webhook (อนุมัติใน DB อย่างเดียว)
N8N_PUBLISH_WEBHOOK="https://your-n8n.example.com/webhook/publish-facebook"

# รหัสผ่านเข้าหน้า /admin (HTTP Basic Auth — username ใส่อะไรก็ได้)
# ถ้าปล่อยว่าง /admin จะเปิดโล่ง (สะดวกตอน dev แต่ห้ามปล่อยว่างบน production)
ADMIN_PASSWORD="change-me"
